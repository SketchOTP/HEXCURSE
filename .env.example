# HexCurse — Taskmaster + local LM Studio (OpenAI-compatible API)
# LM Studio: OpenAI-compatible Local Server (this workspace: Tailscale/LAN host below). Load qwen3.5-2b (~8k context) or match modelId in .taskmaster/config.json.

OPENAI_API_KEY="lm-studio"
OPENAI_BASE_URL="http://100.80.17.40:1234/v1"

# Optional: installer/Taskmaster context caps (default 8000 when unset for LM Studio installs)
# HEXCURSE_LM_STUDIO_MAX_CONTEXT=8000
# HEXCURSE_LM_STUDIO_BASE_URL=http://100.80.17.40:1234

# Optional: before `task-master parse-prd` during `node cursor-governance/setup.js --run-hexcurse*`, require Cursor CLI login (`agent status` after `agent login`). Does not replace Taskmaster's LLM endpoint (OPENAI_* above); it gates the bridge to match headless workflows. See https://cursor.com/docs/cli/reference/authentication.md and https://cursor.com/docs/cli/headless
# HEXCURSE_PREFLIGHT_CURSOR_AGENT=1

# Optional cloud providers (not used for HexCurse Taskmaster defaults)
# ANTHROPIC_API_KEY="..."
# PERPLEXITY_API_KEY="..."
# GOOGLE_API_KEY="..."
# MISTRAL_API_KEY="..."
# XAI_API_KEY="..."
# GROQ_API_KEY="..."
# OPENROUTER_API_KEY="..."
# AZURE_OPENAI_API_KEY="..."
# OLLAMA_API_KEY="..."
# GITHUB_API_KEY="..."
