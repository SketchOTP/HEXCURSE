# HexCurse — Taskmaster + local LM Studio (OpenAI-compatible API)
# LM Studio: enable Local Server (default http://localhost:1234) and load qwen3.5-4b (or match modelId in .taskmaster/config.json).

OPENAI_API_KEY="lm-studio"
OPENAI_BASE_URL="http://localhost:1234/v1"

